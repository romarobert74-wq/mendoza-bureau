rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isElFaro() {
      return request.auth != null && getUserData().rol == 'el_faro';
    }

    function isBureau() {
      return request.auth != null && getUserData().rol == 'bureau';
    }

    function isSocio() {
      return request.auth != null && getUserData().rol == 'socio';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Usuarios: cada uno ve el suyo; bureau y el_faro ven todos
    match /usuarios/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || isBureau() || isElFaro()
      );
      allow create: if isElFaro();
      allow update: if isElFaro() || (isBureau() && request.auth.uid == userId);
      allow delete: if isElFaro();
    }

    // Socios: lectura pública (el tour virtual y la web institucional los leen sin login).
    // Crear: público (formulario del socio). Editar / borrar: solo roles internos.
    match /socios/{socioId} {
      allow read: if true;
      allow create: if true;
      allow update: if isElFaro() || (
        isBureau() && !(
          'urlInternaTour' in request.resource.data ||
          'urlInternaVuelta' in request.resource.data ||
          'urlDrive' in request.resource.data
        )
      );
      allow delete: if isElFaro();

      // Fotos del socio: lectura pública (galería en el tour), escritura solo interna
      match /fotos/{fotoId} {
        allow read: if true;
        allow write: if isBureau() || isElFaro();
      }
    }

    // Configuración del sistema (departamentos, categorías, tour madre, chatbot, logo, etc.):
    // lectura pública porque el tour y la web institucional la necesitan sin login.
    // Escritura solo el_faro, salvo el contador de uso del bot que escribe la API sin auth.
    match /configuracion/chatbot_uso {
      allow read: if true;
      allow write: if true;
    }
    // Plan de migración: info interna, no la necesita el tour ni la web pública
    match /configuracion/migracion {
      allow read: if isAuthenticated();
      allow write: if isElFaro();
    }
    match /configuracion/{docId} {
      allow read: if true;
      allow write: if isElFaro();
    }

    // Web institucional pública: lectura libre, escritura solo roles internos
    match /web_bureau/{docId} {
      allow read: if true;
      allow write: if isBureau() || isElFaro();
    }
    match /web_bureau_prensa/{docId} {
      allow read: if true;
      allow write: if isBureau() || isElFaro();
    }
    match /web_bureau_observatorio/{docId} {
      allow read: if true;
      allow write: if isBureau() || isElFaro();
    }

    // Analytics / clicks: escritura pública (desde tours), lectura con rol
    match /analytics/{docId} {
      allow create: if true;
      allow read: if isAuthenticated();
      allow update, delete: if isElFaro();
    }
  }
}
